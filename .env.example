# This is an example of your .env file format, which pnpm db:setup will create.
# Note: this must be .env, not .env.local, without further configuration changes.
POSTGRES_URL=postgresql://***
STRIPE_SECRET_KEY=sk_test_***
STRIPE_WEBHOOK_SECRET=whsec_***
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_***
BASE_URL=http://localhost:3000
AUTH_SECRET=***

# Cloudflare R2
R2_ACCOUNT_ID=***
R2_ACCESS_KEY_ID=***
R2_SECRET_ACCESS_KEY=***
R2_BUCKET=ecommerce-video-dev
R2_PUBLIC_BASE_URL=https://cdn.yourdomain.com

# Trigger.dev
TRIGGER_SECRET_KEY=***
TRIGGER_PROJECT_REF=***

# fal.ai
FAL_KEY=***
FAL_DEFAULT_MODEL=fal-ai/wan/v2.7/image-to-video

# Generation cost guards
GENERATION_SIGNUP_FREE_CREDITS=30
GENERATION_FREE_QUOTA_LIMIT=3
GENERATION_DAILY_LIMIT=100
GENERATION_ACTIVE_CONCURRENCY_LIMIT=1

# Email
RESEND_API_KEY=***
EMAIL_FROM=Video Maker <no-reply@yourdomain.com>

# Observability
SENTRY_DSN=***
NEXT_PUBLIC_SENTRY_DSN=***
NEXT_PUBLIC_POSTHOG_KEY=***
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
